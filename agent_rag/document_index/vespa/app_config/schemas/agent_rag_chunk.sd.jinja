# Agent RAG Chunk Schema - Vespa Document Schema Definition
# This template is rendered with Jinja2 to support configurable embedding dimensions and features

schema {{ schema_name }} {
    # Knowledge Graph relationship structure
    struct kg_relationship {
        field source type string {}
        field rel_type type string {}
        field target type string {}
    }

    document {{ schema_name }} {
        {% if multi_tenant %}
        # Multi-tenant isolation field
        field tenant_id type string {
            indexing: summary | attribute
            rank: filter
            attribute: fast-search
        }
        {% endif %}

        # ========== Identity Fields ==========
        # Primary document identifier (not the Vespa internal UUID)
        field document_id type string {
            indexing: summary | attribute
            rank: filter
            attribute: fast-search
        }

        # Chunk sequence number within document
        field chunk_id type int {
            indexing: summary | attribute
        }

        # Human-readable identifier for UI display
        field semantic_identifier type string {
            indexing: summary | attribute
        }

        # ========== Content Fields ==========
        # Document title (BM25 indexed for keyword search)
        field title type string {
            indexing: summary | index | attribute
            index: enable-bm25
        }

        # Main content (BM25 indexed for keyword search)
        field content type string {
            indexing: summary | index
            index: enable-bm25
        }

        # Dynamic summary for highlighting (separate from content for performance)
        field content_summary type string {
            indexing: summary | index
            summary: dynamic
        }

        # Short excerpt/blurb for display
        field blurb type string {
            indexing: summary | attribute
        }

        # Whether this chunk continues from previous section
        field section_continuation type bool {
            indexing: summary | attribute
        }

        # ========== Embedding Fields ==========
        {% if enable_title_embedding %}
        # Title embedding (single vector, dimension {{ dim }})
        field title_embedding type tensor<{{ embedding_precision }}>(x[{{ dim }}]) {
            indexing: attribute | index
            attribute {
                distance-metric: angular
            }
        }

        # Flag to skip title embedding matching
        field skip_title type bool {
            indexing: attribute
        }
        {% endif %}

        # Content embeddings (supports multiple embeddings per chunk for mini-chunks)
        # "t" is the embedding index, "x" is the dimension
        field embeddings type tensor<{{ embedding_precision }}>(t{},x[{{ dim }}]) {
            indexing: attribute | index
            attribute {
                distance-metric: angular
            }
        }

        # ========== Metadata Fields ==========
        # Source system type (e.g., confluence, google_drive, web)
        field source_type type string {
            indexing: summary | attribute
            rank: filter
            attribute: fast-search
        }

        # Links to source documents (JSON format)
        field source_links type string {
            indexing: summary | attribute
        }

        # General metadata (JSON format)
        field metadata type string {
            indexing: summary | attribute
        }

        # Metadata list for efficient array-based filtering
        field metadata_list type array<string> {
            indexing: summary | attribute
            rank: filter
            attribute: fast-search
        }

        # Semantic metadata suffix (natural language description)
        field metadata_suffix type string {
            indexing: summary | attribute
        }

        # Image file reference (if chunk contains image)
        field image_file_name type string {
            indexing: summary | attribute
        }

        # ========== RAG Context Enhancement Fields ==========
        # Document-level summary for context
        field doc_summary type string {
            indexing: summary | attribute
        }

        # Surrounding chunk context
        field chunk_context type string {
            indexing: summary | attribute
        }

        {% if enable_large_chunks %}
        # Reference IDs for large chunk mode (points to smaller chunks)
        field large_chunk_reference_ids type array<int> {
            indexing: summary | attribute
        }
        {% endif %}

        # ========== Knowledge Graph Fields ==========
        {% if enable_knowledge_graph %}
        # Entity mentions in this chunk
        field kg_entities type array<string> {
            indexing: summary | attribute
            attribute: fast-search
        }

        # Relationship triplets (source, rel_type, target)
        field kg_relationships type array<kg_relationship> {
            indexing: summary
            struct-field source {
                indexing: attribute
                attribute: fast-search
            }
            struct-field rel_type {
                indexing: attribute
                attribute: fast-search
            }
            struct-field target {
                indexing: attribute
                attribute: fast-search
            }
        }

        # Key terms extracted from chunk
        field kg_terms type array<string> {
            indexing: summary | attribute
            attribute: fast-search
        }
        {% endif %}

        # ========== Ranking & Boost Fields ==========
        # User feedback based boost (-inf to +inf, 0 = neutral)
        field boost type float {
            indexing: summary | attribute
        }

        # Aggregated boost factor (e.g., for low-content detection)
        field aggregated_chunk_boost_factor type float {
            indexing: attribute
        }

        # Document last updated timestamp (Unix epoch seconds)
        field doc_updated_at type int {
            indexing: summary | attribute
        }

        # Hidden document flag (for soft delete)
        field hidden type bool {
            indexing: summary | attribute
            rank: filter
        }

        # ========== Ownership Fields ==========
        field primary_owners type array<string> {
            indexing: summary | attribute
        }

        field secondary_owners type array<string> {
            indexing: summary | attribute
        }

        {% if enable_access_control %}
        # ========== Access Control Fields ==========
        # ACL for permission filtering (weighted set for efficient lookup)
        field access_control_list type weightedset<string> {
            indexing: summary | attribute
            rank: filter
            attribute: fast-search
        }

        # Document set membership
        field document_sets type weightedset<string> {
            indexing: summary | attribute
            rank: filter
            attribute: fast-search
        }

        # User file ownership
        field user_file type int {
            indexing: summary | attribute
            rank: filter
            attribute: fast-search
        }

        # User folder ownership
        field user_folder type int {
            indexing: summary | attribute
            rank: filter
            attribute: fast-search
        }

        # User project membership
        field user_project type array<int> {
            indexing: summary | attribute
            rank: filter
            attribute: fast-search
        }
        {% endif %}
    }

    # Default fieldset for combined title + content search
    fieldset default {
        fields: content, title
    }

    # ========== Rank Profiles ==========

    # Base rank profile with common functions
    rank-profile default_rank {
        inputs {
            query(decay_factor) double: {{ default_decay_factor }}
        }

        # Document boost function: maps boost value to 0.5x - 2x multiplier
        # Uses stretched sigmoid: 0.5 + sigmoid for negative, 2*sigmoid for positive
        function inline document_boost() {
            expression: if(attribute(boost) < 0, 0.5 + (1 / (1 + exp(-attribute(boost) / 3))), 2 / (1 + exp(-attribute(boost) / 3)))
        }

        # Document age in years (default to ~3 months if no timestamp)
        function inline document_age() {
            expression: max(if(isNan(attribute(doc_updated_at)) == 1, 7890000, now() - attribute(doc_updated_at)) / 31536000, 0)
        }

        # Aggregated chunk boost (default 1.0 if not set)
        function inline aggregated_chunk_boost() {
            expression: if(isNan(attribute(aggregated_chunk_boost_factor)) == 1, 1.0, attribute(aggregated_chunk_boost_factor))
        }

        # Recency bias: decays from 1.0 to 0.75 based on document age
        function inline recency_bias() {
            expression: max(1 / (1 + query(decay_factor) * document_age), 0.75)
        }

        match-features: recency_bias
    }

    # Hybrid search with semantic-first ranking
    rank-profile hybrid_search_semantic_base_{{ dim }} inherits default, default_rank {
        inputs {
            query(query_embedding) tensor<float>(x[{{ dim }}])
            query(alpha) double: 0.5
            query(title_content_ratio) double: 0.2
        }

        {% if enable_title_embedding %}
        # Combined title vector score (max of title and content embedding)
        function title_vector_score() {
            expression {
                max(closeness(field, embeddings), closeness(field, title_embedding))
            }
        }
        {% else %}
        function title_vector_score() {
            expression {
                closeness(field, embeddings)
            }
        }
        {% endif %}

        # First phase: vector similarity for initial ranking
        first-phase {
            {% if enable_title_embedding %}
            expression: query(title_content_ratio) * closeness(field, title_embedding) + (1 - query(title_content_ratio)) * closeness(field, embeddings)
            {% else %}
            expression: closeness(field, embeddings)
            {% endif %}
        }

        # Global phase: weighted combination of semantic and keyword scores
        global-phase {
            expression {
                (
                    # Weighted Vector Similarity Score
                    (
                        query(alpha) * (
                            (query(title_content_ratio) * normalize_linear(title_vector_score))
                            +
                            ((1 - query(title_content_ratio)) * normalize_linear(closeness(field, embeddings)))
                        )
                    )
                    +
                    # Weighted Keyword Similarity Score (BM25)
                    (
                        (1 - query(alpha)) * (
                            (query(title_content_ratio) * normalize_linear(bm25(title)))
                            +
                            ((1 - query(title_content_ratio)) * normalize_linear(bm25(content)))
                        )
                    )
                )
                # Apply boost modifiers
                * document_boost
                * recency_bias
                * aggregated_chunk_boost
            }
            rerank-count: {{ rerank_count }}
        }

        match-features {
            bm25(title)
            bm25(content)
            {% if enable_title_embedding %}
            closeness(field, title_embedding)
            {% endif %}
            closeness(field, embeddings)
            document_boost
            recency_bias
            aggregated_chunk_boost
            closest(embeddings)
        }
    }

    # Hybrid search with keyword-first ranking
    rank-profile hybrid_search_keyword_base_{{ dim }} inherits default, default_rank {
        inputs {
            query(query_embedding) tensor<float>(x[{{ dim }}])
            query(alpha) double: 0.2
            query(title_content_ratio) double: 0.2
        }

        {% if enable_title_embedding %}
        function title_vector_score() {
            expression {
                max(closeness(field, embeddings), closeness(field, title_embedding))
            }
        }
        {% else %}
        function title_vector_score() {
            expression {
                closeness(field, embeddings)
            }
        }
        {% endif %}

        # First phase: BM25 for keyword-first ranking
        first-phase {
            expression: query(title_content_ratio) * bm25(title) + (1 - query(title_content_ratio)) * bm25(content)
        }

        # Same global phase as semantic-first
        global-phase {
            expression {
                (
                    (
                        query(alpha) * (
                            (query(title_content_ratio) * normalize_linear(title_vector_score))
                            +
                            ((1 - query(title_content_ratio)) * normalize_linear(closeness(field, embeddings)))
                        )
                    )
                    +
                    (
                        (1 - query(alpha)) * (
                            (query(title_content_ratio) * normalize_linear(bm25(title)))
                            +
                            ((1 - query(title_content_ratio)) * normalize_linear(bm25(content)))
                        )
                    )
                )
                * document_boost
                * recency_bias
                * aggregated_chunk_boost
            }
            rerank-count: {{ rerank_count }}
        }

        match-features {
            bm25(title)
            bm25(content)
            {% if enable_title_embedding %}
            closeness(field, title_embedding)
            {% endif %}
            closeness(field, embeddings)
            document_boost
            recency_bias
            aggregated_chunk_boost
            closest(embeddings)
        }
    }

    # Admin search profile (heavily weights title)
    rank-profile admin_search inherits default, default_rank {
        first-phase {
            expression: bm25(content) + (5 * bm25(title))
        }
    }

    # Random ranking for sampling
    rank-profile random_rank inherits default {
        first-phase {
            expression: random
        }
    }

    # Pure BM25 keyword search
    rank-profile bm25_only inherits default_rank {
        first-phase {
            expression: bm25(content) + bm25(title)
        }
    }
}
