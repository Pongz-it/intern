# Agent RAG 环境配置文件
# 使用方法：复制此文件为 .env，然后填写相应的值
# 所有 AGENT_RAG_ 前缀的变量都会被自动加载

# =============================================================================
# LLM 大语言模型配置
# =============================================================================

# LLM 提供商
# 可选值：litellm（推荐，支持多种模型）、openai、anthropic、azure、bedrock 等
# 使用 litellm 可以统一接口调用 OpenAI、Claude、Gemini、DeepSeek 等多种模型
AGENT_RAG_LLM_PROVIDER=litellm

# LLM 模型名称
# OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# DeepSeek: deepseek-chat, deepseek-reasoner
# 使用 litellm 时，需要加前缀如 anthropic/claude-3-5-sonnet
AGENT_RAG_LLM_MODEL=gpt-4o

# LLM API 密钥
# 也可以设置提供商特定的环境变量：OPENAI_API_KEY、ANTHROPIC_API_KEY 等
# litellm 会自动识别这些变量
AGENT_RAG_LLM_API_KEY=

# LLM API 基础 URL（可选）
# 用于自定义 API 端点，例如使用 Azure OpenAI 或代理服务器
# 不设置时使用官方默认端点
AGENT_RAG_LLM_API_BASE=

# 最大输出 token 数
# 控制模型单次响应的最大长度，GPT-4o 最大支持 16384
AGENT_RAG_LLM_MAX_TOKENS=4096

# 最大输入 token 数
# 控制上下文窗口大小，用于截断过长的输入
# GPT-4o: 128000, Claude-3: 200000, GPT-3.5: 16385
AGENT_RAG_LLM_MAX_INPUT_TOKENS=128000

# 温度参数（0.0-2.0）
# 0.0 = 确定性输出，适合 RAG 场景
# 0.7 = 较有创意，适合内容生成
# 1.0+ = 高度随机，一般不推荐
AGENT_RAG_LLM_TEMPERATURE=0.0

# API 请求超时时间（秒）
# 复杂任务可能需要较长时间，建议设置 60-180 秒
AGENT_RAG_LLM_TIMEOUT=120

# 推理模型设置
# 针对 OpenAI o1、DeepSeek-R1 等推理模型
# 这些模型内置思维链，不需要额外的 system prompt
AGENT_RAG_LLM_IS_REASONING_MODEL=false

# 推理强度（仅对推理模型有效）
# 可选值：low（快速）、medium（平衡）、high（深度思考）
AGENT_RAG_LLM_REASONING_EFFORT=medium

# =============================================================================
# Embedding 向量嵌入配置
# =============================================================================

# Embedding 提供商
# 推荐使用 litellm，支持 OpenAI、Cohere、Voyage 等多种嵌入模型
AGENT_RAG_EMBEDDING_PROVIDER=litellm

# Embedding 模型名称
# OpenAI: text-embedding-3-small（1536维，便宜）、text-embedding-3-large（3072维，更精确）
# Cohere: embed-english-v3.0, embed-multilingual-v3.0
# 注意：更换模型需要重新索引所有文档
AGENT_RAG_EMBEDDING_MODEL=text-embedding-3-small

# Embedding API 密钥（可选）
# 不设置时自动使用 LLM API 密钥
AGENT_RAG_EMBEDDING_API_KEY=

# Embedding API 基础 URL（可选）
AGENT_RAG_EMBEDDING_API_BASE=

# 向量维度
# 必须与所选模型的输出维度匹配
# text-embedding-3-small: 1536
# text-embedding-3-large: 3072
# text-embedding-ada-002: 1536
AGENT_RAG_EMBEDDING_DIMENSION=1536

# 批处理大小
# 每次 API 调用嵌入的文本数量，提高索引效率
# OpenAI 建议 32-100，过大可能导致超时
AGENT_RAG_EMBEDDING_BATCH_SIZE=32

# =============================================================================
# 文档索引配置
# =============================================================================

# 索引类型
# memory: 内存索引，适合开发测试和小规模数据
# vespa: Vespa 分布式索引，适合生产环境和大规模数据
AGENT_RAG_INDEX_TYPE=memory

# Vespa 服务器配置（当 INDEX_TYPE=vespa 时生效）
# Vespa 主机地址
AGENT_RAG_VESPA_HOST=localhost

# Vespa 端口，默认 8080
AGENT_RAG_VESPA_PORT=8080

# Vespa 应用名称
AGENT_RAG_VESPA_APP_NAME=agent_rag

# Vespa 请求超时时间（秒）
AGENT_RAG_VESPA_TIMEOUT=30

# 内存索引持久化路径（可选）
# 设置后会将内存索引保存到磁盘，重启后自动加载
# 不设置则数据仅保存在内存中
AGENT_RAG_MEMORY_PERSIST_PATH=

# =============================================================================
# Vespa Schema 配置
# 控制 Vespa 索引的结构和功能
# =============================================================================

# Schema 名称
# 对应 Vespa 中的文档类型名称
AGENT_RAG_VESPA_SCHEMA_NAME=agent_rag_chunk

# 向量嵌入维度
# 必须与 Embedding 模型维度一致
AGENT_RAG_VESPA_SCHEMA_DIM=1536

# 向量精度
# float: 32位浮点，精度最高
# bfloat16: 16位，节省 50% 存储，精度略低
# int8: 8位量化，节省 75% 存储，需要校准
AGENT_RAG_VESPA_EMBEDDING_PRECISION=float

# 多租户支持
# 开启后支持按 tenant_id 隔离数据
# 适合 SaaS 多客户场景
AGENT_RAG_VESPA_MULTI_TENANT=false

# 标题嵌入
# 为文档标题单独生成向量，提高标题匹配准确度
# 会增加约 10-20% 的存储和索引时间
AGENT_RAG_VESPA_ENABLE_TITLE_EMBEDDING=true

# 大块引用
# 支持引用原始大文本块，用于上下文扩展
AGENT_RAG_VESPA_ENABLE_LARGE_CHUNKS=true

# 知识图谱字段
# 存储实体、关系、术语等知识图谱信息
# 用于增强语义搜索和知识推理
AGENT_RAG_VESPA_ENABLE_KNOWLEDGE_GRAPH=true

# 访问控制
# 开启后支持文档级别的 ACL 权限控制
# 需要在 chunk 中设置 access_control_list
AGENT_RAG_VESPA_ENABLE_ACCESS_CONTROL=false

# 时间衰减因子（0.0-1.0）
# 控制文档新鲜度对排序的影响
# 0.0: 不考虑时间，1.0: 强时间偏好（新文档排序更高）
# 推荐 0.3-0.5，平衡相关性和时效性
AGENT_RAG_VESPA_DEFAULT_DECAY_FACTOR=0.5
AGENT_RAG_VESPA_DECAY_FACTOR=0.5

# 全局重排数量
# 第一阶段检索后进入精排的文档数量
# 越大排序越准确，但延迟越高
# 推荐 500-2000
AGENT_RAG_VESPA_RERANK_COUNT=1000

# 标题/内容权重比
# 控制标题匹配 vs 内容匹配的相对重要性
# 0.2 = 标题占 20%，内容占 80%
AGENT_RAG_VESPA_TITLE_CONTENT_RATIO=0.2

# Vespa 服务配置
# 冗余副本数，生产环境建议 2-3
AGENT_RAG_VESPA_REDUNDANCY=1

# 可搜索副本数，影响查询吞吐量
AGENT_RAG_VESPA_SEARCHABLE_COPIES=1

# 每节点搜索线程数
AGENT_RAG_VESPA_SEARCH_THREADS=4

# 每节点摘要线程数
AGENT_RAG_VESPA_SUMMARY_THREADS=2

# 索引配置
# 并行索引线程数，提高索引速度
AGENT_RAG_VESPA_NUM_THREADS=32

# 批量索引大小
AGENT_RAG_VESPA_BATCH_SIZE=128

# 索引失败最大重试次数
AGENT_RAG_VESPA_MAX_RETRY_ATTEMPTS=5

# =============================================================================
# 搜索配置
# 控制搜索行为和结果处理
# =============================================================================

# 混合搜索权重 Alpha（0.0-1.0）
# 0.0 = 纯关键词搜索（BM25）
# 1.0 = 纯语义搜索（向量相似度）
# 0.5 = 平衡混合，推荐值
# 0.3 = 偏向关键词，适合精确匹配场景
# 0.7 = 偏向语义，适合概念搜索场景
AGENT_RAG_SEARCH_DEFAULT_HYBRID_ALPHA=0.5

# 关键词查询的 Alpha 值
# 当检测到用户输入是关键词而非自然语言时使用
AGENT_RAG_SEARCH_KEYWORD_HYBRID_ALPHA=0.2

# 搜索返回结果数量
AGENT_RAG_SEARCH_NUM_RESULTS=10

# 单次响应最大 chunk 数量
# 控制发送给 LLM 的上下文大小
AGENT_RAG_SEARCH_MAX_CHUNKS_PER_RESPONSE=15

# 查询扩展
# 使用 LLM 将用户查询扩展为多个语义相关的查询
# 提高召回率，但增加延迟和 API 调用成本
AGENT_RAG_SEARCH_ENABLE_QUERY_EXPANSION=true

# 最大扩展查询数量
AGENT_RAG_SEARCH_MAX_EXPANDED_QUERIES=3

# 文档选择
# 使用 LLM 从搜索结果中选择最相关的文档
# 提高精确率，减少噪音
AGENT_RAG_SEARCH_ENABLE_DOCUMENT_SELECTION=true

# LLM 选择的最大文档数量
AGENT_RAG_SEARCH_MAX_DOCUMENTS_TO_SELECT=10

# 每个 Section 用于相关性判断的 chunk 数量
AGENT_RAG_SEARCH_MAX_CHUNKS_FOR_RELEVANCE=3

# 上下文扩展
# 自动获取匹配 chunk 周围的相邻 chunk
# 提供更完整的上下文信息
AGENT_RAG_SEARCH_ENABLE_CONTEXT_EXPANSION=true

# 扩展时包含的相邻 chunk 数量（前后各 N 个）
AGENT_RAG_SEARCH_CONTEXT_EXPANSION_CHUNKS=2

# 上下文最大 token 数
AGENT_RAG_SEARCH_MAX_CONTEXT_TOKENS=4000

# FULL_DOCUMENT 扩展时前后各取的 chunk 数量
# 对应 onyx 的 FULL_DOC_NUM_CHUNKS_AROUND=5
AGENT_RAG_SEARCH_MAX_FULL_DOCUMENT_CHUNKS=5

# 重排序
# 使用专门的 rerank 模型对结果进行精排
# 推荐模型：cohere-rerank-v3.5, bge-reranker-v2-m3
AGENT_RAG_SEARCH_ENABLE_RERANKING=false

# 重排序模型名称
AGENT_RAG_SEARCH_RERANK_MODEL=

# RRF (Reciprocal Rank Fusion) 参数
# 用于合并多个排序结果列表

# 原始查询权重
AGENT_RAG_SEARCH_ORIGINAL_QUERY_WEIGHT=0.5

# LLM 生成的语义查询权重（较高，因为通常更精确）
AGENT_RAG_SEARCH_LLM_SEMANTIC_QUERY_WEIGHT=1.3

# LLM 生成的关键词查询权重
AGENT_RAG_SEARCH_LLM_KEYWORD_QUERY_WEIGHT=1.0

# LLM 生成的非定制查询权重
AGENT_RAG_SEARCH_LLM_NON_CUSTOM_QUERY_WEIGHT=0.7

# RRF k 参数
# 控制排名融合的平滑程度，通常设为 50-60
# 较小的值更偏向高排名结果
AGENT_RAG_SEARCH_RRF_K_VALUE=50

# =============================================================================
# Agent 代理配置
# =============================================================================

# 代理模式
# chat: 对话模式，适合问答和简单任务
# deep_research: 深度研究模式，多 Agent 并行研究，生成综合报告
AGENT_RAG_AGENT_MODE=chat

# 最大循环次数
# 防止 Agent 陷入无限循环
# chat 模式建议 3-6，复杂任务可设更高
AGENT_RAG_AGENT_MAX_CYCLES=6

# 最大步骤数（可选，不设置则无限制）
AGENT_RAG_AGENT_MAX_STEPS=

# 最大 token 数（可选，用于成本控制）
AGENT_RAG_AGENT_MAX_TOKENS=

# 启用的工具（逗号分隔）
# internal_search: 内部文档搜索
# web_search: 网络搜索（需要 Tavily API）
# open_url: 打开并读取 URL 内容
AGENT_RAG_AGENT_ENABLED_TOOLS=internal_search,web_search,open_url

# 引用功能
# 开启后在回答中自动添加文档引用标记
AGENT_RAG_AGENT_ENABLE_CITATIONS=true

# =============================================================================
# Deep Research 深度研究配置
# 控制多 Agent 研究行为
# =============================================================================

# 编排器最大循环次数
# 控制研究的整体深度
AGENT_RAG_DR_MAX_ORCHESTRATOR_CYCLES=8

# 最大研究迭代次数
# 每次迭代会根据已有发现调整研究方向
AGENT_RAG_DR_MAX_RESEARCH_CYCLES=3

# 最大并行研究 Agent 数量
# 根据 API 配额和硬件资源调整
AGENT_RAG_DR_MAX_RESEARCH_AGENTS=5

# 固定研究 Agent 数量（可选）
# 不设置时由系统自动决定
AGENT_RAG_DR_NUM_RESEARCH_AGENTS=

# 每个 Agent 的最大循环次数（可选）
AGENT_RAG_DR_MAX_AGENT_CYCLES=

# 跳过澄清阶段
# 设为 true 时直接开始研究，不询问用户澄清问题
AGENT_RAG_DR_SKIP_CLARIFICATION=false

# Think 工具
# 为非推理模型（如 GPT-4o）启用结构化思考
# 推理模型（如 o1）不需要此功能
AGENT_RAG_DR_ENABLE_THINK_TOOL=true

# 中间报告最大 token 数
# 控制每轮研究后生成的中间摘要长度
AGENT_RAG_DR_MAX_INTERMEDIATE_REPORT_TOKENS=10000

# 最终报告最大 token 数
AGENT_RAG_DR_MAX_FINAL_REPORT_TOKENS=20000

# =============================================================================
# Ingestion & Indexing 文档摄取与索引配置
# =============================================================================

# -----------------------------------------------------------------------------
# MinIO 对象存储配置
# 用于存储原始文档、解析结果、图片和 OCR 数据
# -----------------------------------------------------------------------------

# MinIO 服务器地址
AGENT_RAG_MINIO_HOST=localhost

# MinIO 端口，默认 9000
AGENT_RAG_MINIO_PORT=9000

# MinIO Access Key（类似用户名）
AGENT_RAG_MINIO_ACCESS_KEY=minioadmin

# MinIO Secret Key（类似密码）
AGENT_RAG_MINIO_SECRET_KEY=minioadmin

# MinIO Bucket 名称
# 所有文档数据都存储在这个 bucket 中
AGENT_RAG_MINIO_BUCKET=agent-rag-data

# 是否使用安全连接（HTTPS）
AGENT_RAG_MINIO_SECURE=false

# MinIO 区域设置（可选）
AGENT_RAG_MINIO_REGION=us-east-1

# -----------------------------------------------------------------------------
# Hatchet 工作流引擎配置
# 用于 DAG 任务编排和异步处理
# -----------------------------------------------------------------------------

# Hatchet 客户端 Token
# 从 Hatchet Dashboard 获取
HATCHET_CLIENT_TOKEN=

# Hatchet 服务器地址
# 自托管：http://localhost:7077
# 云服务：https://app.hatchet.run
HATCHET_SERVER_URL=http://localhost:7077

# TLS 策略
# none: 不使用 TLS（自托管开发环境）
# tls: 使用 TLS（生产环境或云服务）
HATCHET_CLIENT_TLS_STRATEGY=none

# Worker 槽位数量
# 控制单个 worker 可以同时执行的任务数量
HATCHET_WORKER_SLOTS=100

# -----------------------------------------------------------------------------
# Chunking 文档切块配置
# 控制如何将文档分割为可索引的语义块
# -----------------------------------------------------------------------------

# 基础切块大小（token 数）
# 默认 512，适合大多数场景
# 较小值（256-384）：更精确匹配，但上下文较少
# 较大值（768-1024）：更多上下文，但可能包含无关内容
AGENT_RAG_CHUNK_SIZE=512

# 块之间的重叠 token 数
# 0: 无重叠，节省存储
# 64-128: 适度重叠，防止语义被切断
AGENT_RAG_CHUNK_OVERLAP=0

# Blurb（摘要）大小
# 从每个 chunk 开头提取的简短摘要
AGENT_RAG_BLURB_SIZE=128

# 强制严格 token 限制
# true: 严格限制，可能截断内容
# false: 允许略微超出，保持语义完整
AGENT_RAG_STRICT_TOKEN_LIMIT=true

# 是否包含元数据
# 将文档元数据附加到 chunk 末尾，提高检索准确性
AGENT_RAG_INCLUDE_METADATA=true

# 元数据最大占比（0.0-1.0）
# 防止元数据过大挤占内容空间
AGENT_RAG_MAX_METADATA_PERCENTAGE=0.2

# 最小内容 token 数
# 保证每个 chunk 至少有这么多内容 token
AGENT_RAG_CHUNK_MIN_CONTENT=64

# [P0] Multipass 多遍索引
# 启用后生成 mini-chunks，支持更精细的匹配
AGENT_RAG_ENABLE_MULTIPASS=false

# Mini-chunk 大小（用于 multipass）
# 默认 64 tokens，提供细粒度匹配
AGENT_RAG_MINI_CHUNK_SIZE=64

# [P0] Large Chunks 大块组合
# 启用后合并多个 chunk 为大块，提供更广泛的上下文
AGENT_RAG_ENABLE_LARGE_CHUNKS=false

# Large chunk 合并比例
# 4 表示每 4 个普通 chunk 合并为 1 个 large chunk
AGENT_RAG_LARGE_CHUNK_RATIO=4

# [P1] Contextual RAG 上下文增强
# 为每个 chunk 添加文档摘要和块上下文
AGENT_RAG_ENABLE_CONTEXTUAL_RAG=false

# 使用文档摘要
# LLM 生成的整篇文档摘要
AGENT_RAG_USE_DOC_SUMMARY=true

# 使用块上下文
# 当前 chunk 在文档中的位置和主题描述
AGENT_RAG_USE_CHUNK_CONTEXT=true

# 上下文最大 token 数
# doc_summary + chunk_context 的总预留空间
AGENT_RAG_MAX_CONTEXT_TOKENS=512

# [P0] 图片块处理
# 为文档中的图片创建专用 chunk
AGENT_RAG_CREATE_IMAGE_CHUNKS=true

# -----------------------------------------------------------------------------
# Embedding 嵌入配置（针对 Ingestion）
# 注意：这里的配置与上面"Embedding 向量嵌入配置"部分有重叠
# 这些是 Ingestion 阶段特定的配置
# -----------------------------------------------------------------------------

# [P1] Title Embedding 缓存
# 缓存文档标题的 embedding，避免重复计算
AGENT_RAG_EMBEDDING_CACHE_TITLES=true

# Title 缓存大小
# LRU 缓存的最大条目数
AGENT_RAG_TITLE_EMBED_CACHE_SIZE=1000

# [P2] 平均 Summary Embeddings
# 对 doc_summary 和 chunk_context 的 embedding 取平均
AGENT_RAG_AVERAGE_SUMMARY_EMBEDDINGS=false

# 批量 embedding 失败时的行为
# true: 整批失败时报错
# false: 按文档隔离重试（推荐）
AGENT_RAG_FAIL_ON_BATCH_ERROR=false

# 是否重试失败的文档
AGENT_RAG_RETRY_FAILED_DOCUMENTS=true

# Embedding 最大重试次数
AGENT_RAG_EMBEDDING_MAX_RETRIES=3

# 重试延迟（秒）
AGENT_RAG_EMBEDDING_RETRY_DELAY=2.0

# -----------------------------------------------------------------------------
# OCR 光学字符识别配置
# 用于从图片中提取文字
# -----------------------------------------------------------------------------

# 是否启用 OCR
AGENT_RAG_OCR_ENABLED=true

# OCR 提供商
# tesseract: 开源本地 OCR（免费，需安装 tesseract）
# google_vision: Google Cloud Vision API（付费，精度高）
# aws_textract: AWS Textract（付费，支持表格）
AGENT_RAG_OCR_PROVIDER=tesseract

# Google Vision API 配置（当 OCR_PROVIDER=google_vision）
AGENT_RAG_GOOGLE_VISION_API_KEY=

# AWS Textract 配置（当 OCR_PROVIDER=aws_textract）
AGENT_RAG_AWS_ACCESS_KEY_ID=
AGENT_RAG_AWS_SECRET_ACCESS_KEY=
AGENT_RAG_AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Deduplication 去重配置
# 控制如何检测和处理重复文档
# -----------------------------------------------------------------------------

# 是否允许重新索引已存在的文档
# true: 相同内容 hash 也会重新处理
# false: 跳过相同内容 hash 的文档
AGENT_RAG_ALLOW_REINDEX_ON_DEDUP=false

# 是否重新处理失败的文档
# true: 之前失败的文档会被重新处理
# false: 跳过失败的文档
AGENT_RAG_REPROCESS_FAILED_DOCUMENTS=true

# -----------------------------------------------------------------------------
# Parsing 文档解析配置
# 控制各种文档格式的解析行为
# -----------------------------------------------------------------------------

# 最大文档 token 数
# 超过此限制的文档会被截断或拒绝
AGENT_RAG_MAX_DOCUMENT_TOKENS=1000000

# 最大文档字符数（备用限制）
AGENT_RAG_MAX_DOCUMENT_CHARS=10000000

# PDF 解析器选择
# pypdf: 轻量级，速度快
# pdfplumber: 表格支持更好
# auto: 自动选择（推荐）
AGENT_RAG_PDF_PARSER=auto

# 是否提取 PDF 表格
AGENT_RAG_PDF_EXTRACT_TABLES=true

# 是否提取 PDF 图片
AGENT_RAG_PDF_EXTRACT_IMAGES=true

# DOCX 解析器选择
# markitdown: 转换为 Markdown（推荐）
# python-docx: 原生 DOCX 解析
AGENT_RAG_DOCX_PARSER=markitdown

# HTML/URL 内容提取器
# trafilatura: 提取主要内容，去除导航栏等（推荐）
# beautifulsoup: 原始 HTML 解析
AGENT_RAG_HTML_EXTRACTOR=trafilatura

# URL 请求超时时间（秒）
AGENT_RAG_URL_FETCH_TIMEOUT=30

# URL 请求 User-Agent
AGENT_RAG_URL_USER_AGENT=Mozilla/5.0 (compatible; AgentRAG/1.0)

# -----------------------------------------------------------------------------
# Workflow 工作流配置
# 控制 Ingestion Workflow 的执行行为
# -----------------------------------------------------------------------------

# 每个租户的最大并发工作流数
# 防止单个租户占用所有资源
AGENT_RAG_WORKFLOW_MAX_RUNS_PER_TENANT=10

# Fetch Content 全局速率限制（次/分钟）
AGENT_RAG_WORKFLOW_FETCH_RATE_LIMIT_GLOBAL=100

# Fetch Content 租户速率限制（次/分钟）
AGENT_RAG_WORKFLOW_FETCH_RATE_LIMIT_TENANT=50

# OCR 全局速率限制（次/分钟）
# OCR 通常有 API 配额限制
AGENT_RAG_WORKFLOW_OCR_RATE_LIMIT_GLOBAL=30

# OCR 租户速率限制（次/分钟）
AGENT_RAG_WORKFLOW_OCR_RATE_LIMIT_TENANT=5

# Embedding 全局速率限制（次/分钟）
AGENT_RAG_WORKFLOW_EMBEDDING_RATE_LIMIT_GLOBAL=50

# Embedding 租户速率限制（次/分钟）
AGENT_RAG_WORKFLOW_EMBEDDING_RATE_LIMIT_TENANT=10

# 任务执行超时时间（秒）
AGENT_RAG_WORKFLOW_FETCH_TIMEOUT=300
AGENT_RAG_WORKFLOW_PARSE_TIMEOUT=600
AGENT_RAG_WORKFLOW_OCR_TIMEOUT=1800
AGENT_RAG_WORKFLOW_CHUNK_TIMEOUT=600
AGENT_RAG_WORKFLOW_EMBED_TIMEOUT=1200
AGENT_RAG_WORKFLOW_INDEX_TIMEOUT=900

# 任务重试次数
AGENT_RAG_WORKFLOW_FETCH_RETRIES=3
AGENT_RAG_WORKFLOW_PARSE_RETRIES=2
AGENT_RAG_WORKFLOW_OCR_RETRIES=2
AGENT_RAG_WORKFLOW_EMBED_RETRIES=3
AGENT_RAG_WORKFLOW_INDEX_RETRIES=3

# -----------------------------------------------------------------------------
# API 配置
# Ingestion API 服务器设置
# -----------------------------------------------------------------------------

# API 服务器主机
AGENT_RAG_API_HOST=0.0.0.0

# API 服务器端口
AGENT_RAG_API_PORT=8000

# Worker 进程数
# 建议设置为 CPU 核心数
AGENT_RAG_API_WORKERS=4

# 请求超时时间（秒）
AGENT_RAG_API_TIMEOUT=300

# 最大请求体大小（MB）
# 控制可以上传的最大文件大小
AGENT_RAG_API_MAX_BODY_SIZE=100

# 启用 CORS（跨域资源共享）
AGENT_RAG_API_ENABLE_CORS=true

# 允许的 CORS 源（逗号分隔）
# * 表示允许所有源（仅开发环境）
AGENT_RAG_API_CORS_ORIGINS=*

# =============================================================================
# 日志配置
# =============================================================================

# 日志级别
# DEBUG: 详细调试信息，包括 API 调用详情
# INFO: 一般信息，推荐生产环境使用
# WARNING: 警告信息
# ERROR: 仅错误信息
AGENT_RAG_LOG_LEVEL=INFO

# 日志格式
# json: 结构化 JSON 格式，便于日志收集系统解析
# text: 人类可读的文本格式，适合开发调试
AGENT_RAG_LOG_FORMAT=text

# =============================================================================
# Text-to-SQL 配置
# 用于将自然语言转换为 SQL 查询
# =============================================================================

# 是否启用 Text-to-SQL 功能
AGENT_RAG_TEXT_TO_SQL_ENABLED=true

# Schema 缓存目录
AGENT_RAG_TEXT_TO_SQL_SCHEMA_CACHE_DIR=./data/schema_store

# Schema 缓存 TTL（秒）
# 缓存过期时间，过期后会自动重新扫描数据库
AGENT_RAG_TEXT_TO_SQL_SCHEMA_CACHE_TTL=3600

# 最大 SQL 查询结果数量
AGENT_RAG_TEXT_TO_SQL_MAX_RESULTS=1000

# 默认查询结果限制
AGENT_RAG_TEXT_TO_SQL_DEFAULT_LIMIT=100

# 是否启用意图分析
# 启用后会分析用户查询，判断是否为数据查询
AGENT_RAG_TEXT_TO_SQL_INTENT_ANALYSIS=true

# 意图分析置信度阈值
# 当置信度 >= 此值时，认为是数据查询，触发 SQL 执行
AGENT_RAG_TEXT_TO_SQL_INTENT_CONFIDENCE=0.7

# 最大生成 token 数
AGENT_RAG_TEXT_TO_SQL_MAX_TOKENS=1024

# 温度参数（0.0-1.0）
AGENT_RAG_TEXT_TO_SQL_TEMPERATURE=0.0

# 允许查询的表（逗号分隔）
# 空值表示允许所有表
AGENT_RAG_TEXT_TO_SQL_ALLOWED_TABLES=

# 禁止查询的表（逗号分隔）
AGENT_RAG_TEXT_TO_SQL_BLOCKED_TABLES=

# 是否启用审计日志
AGENT_RAG_TEXT_TO_SQL_AUDIT_LOG=true

# =============================================================================
# 外部数据库发现配置
# 启用后会自动扫描外部数据库的表结构、列信息，并生成关键词
# 当用户查询包含这些关键词时，会自动触发 SQL+Vespa 混合查询
# =============================================================================

# 是否启用外部数据库发现功能
AGENT_RAG_TEXT_TO_SQL_DB_DISCOVERY=true

# =============================================================================
# 外部数据库配置
# 通过 /api/hybrid-search 接口同时查询 Vespa 和外部数据库
# PostgreSQL 作为外接数据库使用
# =============================================================================

# 外部数据库类型: postgresql, sqlite, mysql
AGENT_RAG_API_EXTERNAL_DB_TYPE=postgresql

# 外部 PostgreSQL 主机
AGENT_RAG_API_EXTERNAL_DB_HOST=localhost

# 外部 PostgreSQL 端口
AGENT_RAG_API_EXTERNAL_DB_PORT=5432

# 外部 PostgreSQL 用户名
AGENT_RAG_API_EXTERNAL_DB_USERNAME=postgres

# 外部 PostgreSQL 密码
AGENT_RAG_API_EXTERNAL_DB_PASSWORD=password

# 外部 PostgreSQL 数据库名
AGENT_RAG_API_EXTERNAL_DB_DATABASE=agent_rag

# 外部数据库默认查询限制
AGENT_RAG_API_EXTERNAL_DB_DEFAULT_LIMIT=100

# 外部数据库最大结果数量
AGENT_RAG_API_EXTERNAL_DB_MAX_RESULTS=1000
